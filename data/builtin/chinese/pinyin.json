      { "name": "双唇音", "items": ["b","p","m"] },
      { "name": "唇齿音", "items": ["f"] },
      { "name": "舌尖中音", "items": ["d","t","n","l"] },
      { "name": "舌根音", "items": ["g","k","h"] },
      { "name": "舌面音", "items": ["j","q","x"] },
      { "name": "翘舌音", "items": ["zh","ch","sh","r"] },
      { "name": "平舌音", "items": ["z","c","s"] }
    ],
    "cards": [
      {"initial":"b","example":"爸爸 bàba","tip":"上下嘴唇合拢，突然打开"},
      {"initial":"p","example":"葡萄 pútao","tip":"嘴唇合拢，有气流冲出"},
      {"initial":"m","example":"妈妈 māma","tip":"嘴唇合拢，气流从鼻子出"},
      {"initial":"f","example":"飞机 fēijī","tip":"上齿轻触下唇，气流从缝隙出"},
      {"initial":"d","example":"弟弟 dìdi","tip":"舌尖抵住上齿龈，突然松开"},
      {"initial":"t","example":"兔子 tùzi","tip":"舌尖抵住上齿龈，有气流冲出"},
      {"initial":"n","example":"牛奶 niúnǎi","tip":"舌尖抵住上齿龈，气流从鼻子出"},
      {"initial":"l","example":"老师 lǎoshī","tip":"舌尖抵住上齿龈，气流从两侧出"},
      {"initial":"g","example":"哥哥 gēge","tip":"舌根抵住软腭，突然松开"},
      {"initial":"k","example":"开心 kāixīn","tip":"舌根抵住软腭，有气流冲出"},
      {"initial":"h","example":"花朵 huāduǒ","tip":"舌根靠近软腭，气流从缝隙出"},
      {"initial":"j","example":"鸡蛋 jīdàn","tip":"舌面前部抵住上颚，气流从中间出"},
      {"initial":"q","example":"铅笔 qiānbǐ","tip":"舌面前部抵住上颚，有气流冲出"},
      {"initial":"x","example":"西瓜 xīguā","tip":"舌面前部靠近上颚，气流从缝隙出"},
      {"initial":"zh","example":"蜘蛛 zhīzhū","tip":"翘起舌尖，抵住上颚前部"},
      {"initial":"ch","example":"长城 chángchéng","tip":"翘起舌尖，抵住上颚前部，有气流"},
      {"initial":"sh","example":"狮子 shīzi","tip":"翘起舌尖，靠近上颚前部"},
      {"initial":"r","example":"热闹 rènao","tip":"翘起舌尖，靠近上颚，声带振动"},
      {"initial":"z","example":"紫色 zǐsè","tip":"舌尖抵住上齿背，平舌音"},
      {"initial":"c","example":"草地 cǎodì","tip":"舌尖抵住上齿背，有气流，平舌音"},
      {"initial":"s","example":"松鼠 sōngshǔ","tip":"舌尖靠近上齿背，平舌音"}
    ]
  },
