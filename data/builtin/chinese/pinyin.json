  "tones": {
    "title": "声调规则",
    "rules": [
      {"name":"第一声（阴平）","mark":"ā","desc":"高平调，音调平稳保持高音","example":"妈 māma，天 tiān","tip":"像唱歌时拉长的高音"},
      {"name":"第二声（阳平）","mark":"á","desc":"中升调，从中音升到高音","example":"爸 bá，来 lái","tip":"像问「啊？」时的语气"},
      {"name":"第三声（上声）","mark":"ǎ","desc":"降升调，先降后升（实际中常读半三声）","example":"我 wǒ，好 hǎo","tip":"像犹豫时「嗯……」的音"},
      {"name":"第四声（去声）","mark":"à","desc":"全降调，从高音迅速降到低音","example":"是 shì，大 dà","tip":"像回答「对！」时的语气"},
      {"name":"轻声","mark":"·","desc":"短而轻，没有固定音调","example":"吗 ma，呢 ne，吧 ba","tip":"语气助词大多是轻声"}
    ],
    "tone_rules": [
      "有a、o、e，帽子戴在它头上（声调标在a、o、e上）",
      "i、u并列时，声调标在后面（如：guì、liú）",
      "i上标调时，i上的点去掉（ī í ǐ ì）",
      "ü遇到j、q、x、y时，两点省略（如：ju → jū，qu → qū）",
      "三声+三声，第一个变二声（如：你好 nǐhǎo → níhǎo）"
    ]
  },
