{
  "meta": { "subject": "math", "grade": "primary", "name": "小学数学概念", "version": "2024", "count": 25 },
  "cards": [
    { "id": "pc_001", "type": "concept", "front": "奇数", "back": "不能被2整除的整数（1,3,5,7,9...）", "hint": "个位是1,3,5,7,9的数", "tags": ["整数","概念"] },
    { "id": "pc_002", "type": "concept", "front": "偶数", "back": "能被2整除的整数（0,2,4,6,8...）", "hint": "个位是0,2,4,6,8的数，0也是偶数", "tags": ["整数","概念"] },
    { "id": "pc_003", "type": "concept", "front": "因数（约数）", "back": "整数a能被整数b整除，b就是a的因数\n例：12的因数有1,2,3,4,6,12", "hint": "能整除这个数的数", "tags": ["整除","概念"] },
    { "id": "pc_004", "type": "concept", "front": "倍数", "back": "a=b×c，a就是b和c的倍数\n例：12是3的倍数，因为12=3×4", "hint": "某数的整数倍", "tags": ["整除","概念"] },
    { "id": "pc_005", "type": "concept", "front": "公因数", "back": "几个数公有的因数\n例：12和18的公因数有1,2,3,6", "hint": "几个数共同的因数", "tags": ["整除","公因数"] },
    { "id": "pc_006", "type": "concept", "front": "最大公因数（GCF/HCF）", "back": "公因数中最大的那个\n例：GCF(12,18)=6", "hint": "最大的那个公因数", "tags": ["整除","公因数"] },
    { "id": "pc_007", "type": "concept", "front": "公倍数", "back": "几个数公有的倍数\n例：3和4的公倍数有12,24,36...", "tags": ["整除","公倍数"] },
    { "id": "pc_008", "type": "concept", "front": "最小公倍数（LCM）", "back": "公倍数中最小的那个（不含0）\n例：LCM(3,4)=12", "hint": "最小的正公倍数", "tags": ["整除","公倍数"] },
    { "id": "pc_009", "type": "concept", "front": "约分", "back": "把分数的分子和分母同除以它们的公因数，使分数化简\n最简分数：分子分母互质（公因数只有1）", "example": "12/18 = 6/9 = 2/3（最简）", "tags": ["分数"] },
    { "id": "pc_010", "type": "concept", "front": "通分", "back": "把几个异分母分数化成同分母分数\n以LCM为公分母", "example": "1/3和1/4通分：分母取LCM=12\n→ 4/12和3/12", "tags": ["分数"] },
    { "id": "pc_011", "type": "concept", "front": "假分数与带分数", "back": "假分数：分子≥分母（如7/3）\n带分数：整数+真分数（如2⅓）\n7/3 = 2⅓（互相换算）", "tags": ["分数"] },
    { "id": "pc_012", "type": "concept", "front": "比（ratio）", "back": "两个数相比叫做比，如a:b（b≠0）\na:b = a/b\n前项:后项 = 比值", "example": "3:4，比值=3/4=0.75", "tags": ["比例"] },
    { "id": "pc_013", "type": "concept", "front": "百分数", "back": "表示一个数是另一个数的百分之几\n百分数 = 分子/100 = 小数×100%", "example": "75% = 75/100 = 0.75", "tags": ["百分数"] },
    { "id": "pc_014", "type": "concept", "front": "数轴", "back": "用一条直线上的点表示数\n向右为正方向，0为原点\n每个点对应唯一的数", "tags": ["整数","数轴"] },
    { "id": "pc_015", "type": "concept", "front": "正数、负数、零", "back": "大于0的数是正数，小于0的数是负数，0既不正也不负\n0是最小的非负整数", "hint": "温度、海拔等都会用到负数", "tags": ["整数","概念"] },
    { "id": "pc_016", "type": "concept", "front": "平均数", "back": "一组数据的总和 ÷ 数据个数\n= (a₁+a₂+...+aₙ) / n", "example": "5个同学成绩：80,90,85,70,75\n平均 = (80+90+85+70+75)÷5 = 80", "tags": ["统计","概念"] },
    { "id": "pc_017", "type": "concept", "front": "中位数", "back": "将数据从小到大排列后，位于中间的数\n偶数个数据：取中间两数的平均值", "example": "1,3,5,7,9 → 中位数=5\n1,3,5,7 → 中位数=(3+5)/2=4", "tags": ["统计","概念"] },
    { "id": "pc_018", "type": "concept", "front": "众数", "back": "一组数据中出现次数最多的数\n可以有多个众数，也可以没有", "example": "1,2,2,3,3,3,4 → 众数=3", "tags": ["统计","概念"] },
    { "id": "pc_019", "type": "concept", "front": "直角（90°）", "back": "两条直线互相垂直所成的角是直角\n90°是直角，小于90°是锐角，大于90°是钝角", "tags": ["图形","角"] },
    { "id": "pc_020", "type": "concept", "front": "轴对称图形", "back": "沿一条直线对折，两边完全重合的图形\n正方形有4条对称轴，长方形有2条，圆有无数条", "tags": ["图形","对称"] },
    { "id": "pc_021", "type": "concept", "front": "体积与容积的区别", "back": "体积：物体占空间的大小\n容积：容器内能容纳物体的体积\n通常容积≤体积（容器有壁厚）", "tags": ["立体图形"] },
    { "id": "pc_022", "type": "concept", "front": "分数、小数、百分数互化", "back": "分数→小数：分子÷分母\n小数→百分数：×100%\n百分数→小数：÷100（去掉%）\n小数→分数：按位值写，再约分", "example": "3/4=0.75=75%", "tags": ["分数","小数","百分数"] },
    { "id": "pc_023", "type": "concept", "front": "整除的判断规则", "back": "被2整除：末位是偶数\n被3整除：各位数字之和能被3整除\n被5整除：末位是0或5\n被9整除：各位数字之和能被9整除", "example": "123：1+2+3=6，能被3整除", "tags": ["整除"] },
    { "id": "pc_024", "type": "concept", "front": "圆心角与圆的关系", "back": "圆心角360°对应整个圆\n扇形的面积 = (圆心角/360°)×圆面积", "tags": ["圆","图形"] },
    { "id": "pc_025", "type": "concept", "front": "排列与组合（基础）", "back": "排列：注意顺序，从n个中取m个：A(n,m)=n!/(n-m)!\n组合：不注意顺序，从n个中取m个：C(n,m)=n!/[m!(n-m)!]", "example": "从3人选2人排队：A(3,2)=6种\n从3人选2人组队：C(3,2)=3种", "tags": ["统计","排列组合"] }
  ]
}
