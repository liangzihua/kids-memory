    { "id": "math_071", "type": "word", "front": "等差数列求和", "back": "Sₙ = n(a₁+aₙ)/2 = na₁ + n(n-1)d/2（d为公差）", "phonetic": "", "hint": "首末相加乘以项数除以2；等差数列每相邻两项之差相等", "example": "1+2+3+...+100=100×(1+100)/2=5050", "tags": ["数学","公式","初中","数列"] },
    { "id": "math_072", "type": "word", "front": "等比数列求和", "back": "Sₙ = a₁(1-qⁿ)/(1-q)（q≠1，q为公比）", "phonetic": "", "hint": "等比数列每相邻两项之比相等，求和用公式", "example": "1+2+4+8+...+2^9，q=2，S=1×(1-2^10)/(1-2)=1023", "tags": ["数学","公式","初中","数列"] },
    { "id": "math_073", "type": "word", "front": "整数计数原理（加法）", "back": "若事件A有m种方法，事件B有n种方法，二者互斥，则共有m+n种方法", "phonetic": "", "hint": "分步选择用乘法，分类选择用加法", "example": "从3条路中选1条去A或B地，A地2条，B地1条，共2+1=3种", "tags": ["数学","公式","初中","排列组合"] },
    { "id": "math_074", "type": "word", "front": "整数计数原理（乘法）", "back": "若第一步有m种选择，第二步有n种选择，则共有m×n种方法", "phonetic": "", "hint": "分步进行且步骤互相独立，用乘法原理", "example": "上衣3件，裤子4条，搭配方式=3×4=12种", "tags": ["数学","公式","初中","排列组合"] },
    { "id": "math_075", "type": "word", "front": "排列数公式", "back": "Aₙᵐ = n!/(n-m)! = n×(n-1)×...×(n-m+1)", "phonetic": "", "hint": "从n个中选m个有顺序地排列，A₃² =3×2=6", "example": "从5人中选3人排队：A₅³=5×4×3=60种", "tags": ["数学","公式","初中","排列组合"] },
    { "id": "math_076", "type": "word", "front": "组合数公式", "back": "Cₙᵐ = n!/[m!(n-m)!] = Aₙᵐ/m!", "phonetic": "", "hint": "从n个中选m个不计顺序，C₅² =10", "example": "从5人选3人：C₅³=5!/(3!2!)=10种", "tags": ["数学","公式","初中","排列组合"] },
