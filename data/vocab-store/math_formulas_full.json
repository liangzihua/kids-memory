    { "id": "math_060", "type": "word", "front": "幂的乘方", "back": "(aᵐ)ⁿ = aᵐⁿ", "phonetic": "", "hint": "幂的幂运算：指数相乘", "example": "(2³)² = 2⁶ = 64", "tags": ["数学","公式","初中","幂运算"] },
