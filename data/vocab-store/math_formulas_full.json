{
  "meta": { "subject": "math", "grade": "primary", "name": "数学公式大全（扩展版）", "version": "2024", "count": 80 },
  "cards": [
    { "id": "math_001", "type": "word", "front": "正方形周长", "back": "C = 4a（a为边长）", "phonetic": "", "hint": "正方形四边相等，周长=边长×4", "example": "边长5cm的正方形，周长=4×5=20cm", "tags": ["数学","公式","小学","周长"] },
    { "id": "math_002", "type": "word", "front": "正方形面积", "back": "S = a²（a为边长）", "phonetic": "", "hint": "正方形面积=边长的平方", "example": "边长4cm，面积=4²=16cm²", "tags": ["数学","公式","小学","面积"] },
    { "id": "math_003", "type": "word", "front": "长方形周长", "back": "C = 2(a+b)（a=长，b=宽）", "phonetic": "", "hint": "周长=（长+宽）×2", "example": "长6cm宽4cm，周长=2×(6+4)=20cm", "tags": ["数学","公式","小学","周长"] },
    { "id": "math_004", "type": "word", "front": "长方形面积", "back": "S = a × b（a=长，b=宽）", "phonetic": "", "hint": "面积=长×宽", "example": "长6cm宽4cm，面积=6×4=24cm²", "tags": ["数学","公式","小学","面积"] },
    { "id": "math_005", "type": "word", "front": "三角形面积", "back": "S = ½ × a × h（a=底，h=高）", "phonetic": "", "hint": "面积=底×高÷2，同底同高三角形面积等于平行四边形一半", "example": "底8cm高5cm，面积=½×8×5=20cm²", "tags": ["数学","公式","小学","面积"] },
    { "id": "math_006", "type": "word", "front": "平行四边形面积", "back": "S = a × h（a=底，h=高）", "phonetic": "", "hint": "面积=底×高（高是垂直于底的距离）", "example": "底10cm高4cm，面积=10×4=40cm²", "tags": ["数学","公式","小学","面积"] },
    { "id": "math_007", "type": "word", "front": "梯形面积", "back": "S = ½ × (a+b) × h（a=上底，b=下底，h=高）", "phonetic": "", "hint": "面积=（上底+下底）×高÷2", "example": "上底3，下底5，高4，面积=½×(3+5)×4=16", "tags": ["数学","公式","小学","面积"] },
    { "id": "math_008", "type": "word", "front": "圆的周长", "back": "C = 2πr = πd（r=半径，d=直径）", "phonetic": "", "hint": "周长=π×直径=2×π×半径，π≈3.14", "example": "半径3cm，周长=2×3.14×3≈18.84cm", "tags": ["数学","公式","小学","周长","圆"] },
    { "id": "math_009", "type": "word", "front": "圆的面积", "back": "S = πr²（r=半径）", "phonetic": "", "hint": "面积=π×半径²，π≈3.14", "example": "半径5cm，面积=3.14×5²=78.5cm²", "tags": ["数学","公式","小学","面积","圆"] },
    { "id": "math_010", "type": "word", "front": "长方体体积", "back": "V = a × b × c（长×宽×高）", "phonetic": "", "hint": "体积=长×宽×高", "example": "长4宽3高2，体积=4×3×2=24cm³", "tags": ["数学","公式","小学","体积"] },
    { "id": "math_011", "type": "word", "front": "正方体体积", "back": "V = a³（a=棱长）", "phonetic": "", "hint": "体积=棱长的三次方=棱长³", "example": "棱长3cm，体积=3³=27cm³", "tags": ["数学","公式","小学","体积"] },
    { "id": "math_012", "type": "word", "front": "长方体表面积", "back": "S = 2(ab + bc + ac)", "phonetic": "", "hint": "六个面：顶底两个ab，前后两个bc，左右两个ac", "example": "长4宽3高2，S=2×(4×3+3×2+4×2)=52cm²", "tags": ["数学","公式","小学","表面积"] },
    { "id": "math_013", "type": "word", "front": "正方体表面积", "back": "S = 6a²（a=棱长）", "phonetic": "", "hint": "六个相同正方形面，S=6×边长²", "example": "棱长3cm，S=6×3²=54cm²", "tags": ["数学","公式","小学","表面积"] },
    { "id": "math_014", "type": "word", "front": "圆柱体积", "back": "V = πr²h（r=底面半径，h=高）", "phonetic": "", "hint": "体积=底面积×高=πr²×h", "example": "半径2高5，V=3.14×4×5=62.8cm³", "tags": ["数学","公式","小学","体积"] },
    { "id": "math_015", "type": "word", "front": "圆柱表面积", "back": "S = 2πr² + 2πrh（r=半径，h=高）", "phonetic": "", "hint": "两个底面圆+侧面展开长方形", "example": "底面积+侧面积，侧面展开=2πr×h", "tags": ["数学","公式","小学","表面积"] },
    { "id": "math_016", "type": "word", "front": "圆锥体积", "back": "V = ⅓ πr²h（r=底面半径，h=高）", "phonetic": "", "hint": "圆锥体积=同底同高圆柱体积的三分之一", "example": "同底同高圆柱V=60cm³，则圆锥V=60÷3=20cm³", "tags": ["数学","公式","小学","体积"] },
    { "id": "math_017", "type": "word", "front": "分数乘整数", "back": "a/b × n = (a×n)/b", "phonetic": "", "hint": "分子乘以整数，分母不变", "example": "2/3 × 6 = (2×6)/3 = 12/3 = 4", "tags": ["数学","公式","小学","分数"] },
    { "id": "math_018", "type": "word", "front": "分数除以整数", "back": "a/b ÷ n = a/(b×n)", "phonetic": "", "hint": "分母乘以整数，分子不变（等于乘以倒数）", "example": "2/3 ÷ 4 = 2/(3×4) = 2/12 = 1/6", "tags": ["数学","公式","小学","分数"] },
    { "id": "math_019", "type": "word", "front": "分数加减法（同分母）", "back": "a/c ± b/c = (a±b)/c", "phonetic": "", "hint": "同分母分数加减：分子相加减，分母不变", "example": "3/7 + 2/7 = 5/7；5/7 - 2/7 = 3/7", "tags": ["数学","公式","小学","分数"] },
    { "id": "math_020", "type": "word", "front": "分数加减法（异分母）", "back": "a/b ± c/d = (ad ± bc)/(bd)，通分后计算", "phonetic": "", "hint": "先通分（化为同分母），再按同分母方法计算", "example": "1/2 + 1/3 = 3/6 + 2/6 = 5/6", "tags": ["数学","公式","小学","分数"] },
    { "id": "math_021", "type": "word", "front": "分数与小数互化", "back": "分数→小数：分子除以分母；小数→分数：按位数写分母", "phonetic": "", "hint": "1/4=0.25；0.6=6/10=3/5", "example": "3/4=3÷4=0.75；0.125=125/1000=1/8", "tags": ["数学","公式","小学","分数","小数"] },
    { "id": "math_022", "type": "word", "front": "百分数与小数互化", "back": "百分数→小数：去掉%，小数点左移两位；反之右移", "phonetic": "", "hint": "60%=0.60=0.6；0.75=75%", "example": "35%=0.35；1.2=120%", "tags": ["数学","公式","小学","百分数"] },
    { "id": "math_023", "type": "word", "front": "百分数与分数互化", "back": "百分数→分数：以100为分母；分数→百分数：分子÷分母×100%", "phonetic": "", "hint": "25%=25/100=1/4；3/5=0.6=60%", "example": "40%=40/100=2/5；2/5=0.4=40%", "tags": ["数学","公式","小学","百分数","分数"] },
    { "id": "math_024", "type": "word", "front": "求一个数的百分之几", "back": "结果 = 总数 × 百分率", "phonetic": "", "hint": "例：全班40人，60%参加活动，人数=40×60%=24人", "example": "200件产品，98%合格，合格=200×98%=196件", "tags": ["数学","公式","小学","百分数"] },
    { "id": "math_025", "type": "word", "front": "比例关系", "back": "a:b = c:d ⟺ ad = bc（外项积=内项积）", "phonetic": "", "hint": "两个内项之积等于两个外项之积", "example": "2:3=4:6，验证：2×6=3×4=12 ✓", "tags": ["数学","公式","小学","比例"] },
    { "id": "math_026", "type": "word", "front": "速度公式", "back": "速度 = 路程 ÷ 时间；路程 = 速度 × 时间；时间 = 路程 ÷ 速度", "phonetic": "", "hint": "v=s/t，s=vt，t=s/v。三个量知道两个可求第三个", "example": "路程120km，时间2h，速度=120÷2=60km/h", "tags": ["数学","公式","小学","行程"] },
    { "id": "math_027", "type": "word", "front": "工程问题基本公式", "back": "效率 × 时间 = 工作量；效率 = 工作量 ÷ 时间", "phonetic": "", "hint": "设总工程量为1，各自效率×时间=1", "example": "甲10天完成，甲效率=1/10；合做：1/10+1/15=1/6，需6天", "tags": ["数学","公式","小学","工程"] },
    { "id": "math_028", "type": "word", "front": "行程追及问题", "back": "追及时间 = 追及距离 ÷ 速度差", "phonetic": "", "hint": "同向追及：时间=距离差÷(快速-慢速)", "example": "甲先出发2h，速度4km/h；乙速度6km/h，追及时间=4×2÷(6-4)=4h", "tags": ["数学","公式","小学","行程"] },
    { "id": "math_029", "type": "word", "front": "行程相遇问题", "back": "相遇时间 = 总路程 ÷ 速度和", "phonetic": "", "hint": "两人相向而行，时间=总距离÷（甲速+乙速）", "example": "相距200km，甲40km/h，乙60km/h，相遇时间=200÷(40+60)=2h", "tags": ["数学","公式","小学","行程"] },
    { "id": "math_030", "type": "word", "front": "利润问题", "back": "利润 = 售价 - 成本；利润率 = 利润 ÷ 成本 × 100%", "phonetic": "", "hint": "售价=成本×(1+利润率)", "example": "成本200元，售价250元，利润=50元，利润率=50÷200=25%", "tags": ["数学","公式","小学","百分数"] },
    { "id": "math_031", "type": "word", "front": "勾股定理", "back": "直角三角形：a² + b² = c²（c为斜边）", "phonetic": "", "hint": "两直角边的平方和等于斜边的平方。常用：3²+4²=5²", "example": "两直角边3、4，斜边=√(9+16)=√25=5", "tags": ["数学","公式","初中","几何"] },
    { "id": "math_032", "type": "word", "front": "勾股定理逆定理", "back": "若a²+b²=c²，则该三角形是直角三角形", "phonetic": "", "hint": "可用于判断三角形是否为直角三角形", "example": "边长5、12、13：5²+12²=25+144=169=13² ✓ 直角三角形", "tags": ["数学","公式","初中","几何"] },
    { "id": "math_033", "type": "word", "front": "一元二次方程求根公式", "back": "ax²+bx+c=0，x = [-b ± √(b²-4ac)] / 2a", "phonetic": "", "hint": "判别式Δ=b²-4ac：Δ>0两根，Δ=0重根，Δ<0无实根", "example": "x²-5x+6=0，x=(5±√1)/2，x=3或x=2", "tags": ["数学","公式","初中","方程"] },
    { "id": "math_034", "type": "word", "front": "韦达定理（根与系数关系）", "back": "ax²+bx+c=0的两根x₁、x₂：x₁+x₂=-b/a；x₁×x₂=c/a", "phonetic": "", "hint": "两根之和=-b/a，两根之积=c/a", "example": "x²-5x+6=0，根之和=5，根之积=6，即x=2,3", "tags": ["数学","公式","初中","方程"] },
    { "id": "math_035", "type": "word", "front": "正弦sin（三角函数）", "back": "sin θ = 对边/斜边", "phonetic": "", "hint": "SOH：Sine=Opposite/Hypotenuse，sin30°=0.5", "example": "30度角：sin30°=1/2=0.5；sin90°=1", "tags": ["数学","公式","初中","三角函数"] },
    { "id": "math_036", "type": "word", "front": "余弦cos（三角函数）", "back": "cos θ = 邻边/斜边", "phonetic": "", "hint": "CAH：Cosine=Adjacent/Hypotenuse，cos60°=0.5", "example": "60度角：cos60°=1/2=0.5；cos0°=1", "tags": ["数学","公式","初中","三角函数"] },
    { "id": "math_037", "type": "word", "front": "正切tan（三角函数）", "back": "tan θ = 对边/邻边 = sin θ / cos θ", "phonetic": "", "hint": "TOA：Tangent=Opposite/Adjacent，tan45°=1", "example": "45度角：tan45°=1；tan30°=√3/3≈0.577", "tags": ["数学","公式","初中","三角函数"] },
    { "id": "math_038", "type": "word", "front": "三角函数特殊值（30°）", "back": "sin30°=1/2，cos30°=√3/2，tan30°=√3/3", "phonetic": "", "hint": "30°对应等边三角形的一半", "example": "sin30°=0.5，cos30°≈0.866，tan30°≈0.577", "tags": ["数学","公式","初中","三角函数"] },
    { "id": "math_039", "type": "word", "front": "三角函数特殊值（45°）", "back": "sin45°=cos45°=√2/2，tan45°=1", "phonetic": "", "hint": "45°等腰直角三角形，两直角边相等", "example": "sin45°=cos45°=√2/2≈0.707，tan45°=1", "tags": ["数学","公式","初中","三角函数"] },
    { "id": "math_040", "type": "word", "front": "三角函数特殊值（60°）", "back": "sin60°=√3/2，cos60°=1/2，tan60°=√3", "phonetic": "", "hint": "60°是30°的互余角，sin60°=cos30°", "example": "sin60°≈0.866，cos60°=0.5，tan60°≈1.732", "tags": ["数学","公式","初中","三角函数"] },
    { "id": "math_041", "type": "word", "front": "圆的切线性质", "back": "切线⊥过切点的半径；切线长L=√(d²-r²)（d=圆心到点距离，r=半径）", "phonetic": "", "hint": "切线与半径垂直，切线从圆外一点可作两条切线且长相等", "example": "圆心到外点距离5，半径3，切线长=√(25-9)=4", "tags": ["数学","公式","初中","圆"] },
    { "id": "math_042", "type": "word", "front": "圆心角弧长公式", "back": "弧长 l = (n/360) × 2πr（n=圆心角度数）", "phonetic": "", "hint": "弧长=圆心角度数/360° × 周长", "example": "半径6，圆心角60°，弧长=60/360×2π×6=2π", "tags": ["数学","公式","初中","圆"] },
    { "id": "math_043", "type": "word", "front": "扇形面积", "back": "S = (n/360) × πr²（n=圆心角度数）", "phonetic": "", "hint": "扇形面积=圆心角度数/360° × 圆面积", "example": "半径6，圆心角90°，面积=90/360×π×36=9π", "tags": ["数学","公式","初中","圆"] },
    { "id": "math_044", "type": "word", "front": "平均数", "back": "x̄ = (x₁+x₂+...+xₙ) / n", "phonetic": "", "hint": "所有数据之和除以数据个数", "example": "数据：2,4,6,8，平均数=(2+4+6+8)/4=5", "tags": ["数学","公式","初中","统计"] },
    { "id": "math_045", "type": "word", "front": "中位数", "back": "将数据从小到大排列后，最中间的那个数（偶数个取中间两个的平均值）", "phonetic": "", "hint": "奇数个：正中间那个；偶数个：中间两个的平均值", "example": "1,3,5,7,9中位数=5；1,2,3,4中位数=(2+3)/2=2.5", "tags": ["数学","公式","初中","统计"] },
    { "id": "math_046", "type": "word", "front": "众数", "back": "一组数据中出现次数最多的数", "phonetic": "", "hint": "出现频率最高的数据，可能有多个或无众数", "example": "1,2,2,3,3,3,4中众数=3（出现3次）", "tags": ["数学","公式","初中","统计"] },
    { "id": "math_047", "type": "word", "front": "方差", "back": "s² = [(x₁-x̄)²+(x₂-x̄)²+...+(xₙ-x̄)²] / n", "phonetic": "", "hint": "各数据与平均数之差的平方的平均值，反映数据的分散程度", "example": "数据1,3,5，平均数3，s²=[(1-3)²+(3-3)²+(5-3)²]/3=8/3", "tags": ["数学","公式","初中","统计"] },
    { "id": "math_048", "type": "word", "front": "标准差", "back": "s = √s²（方差的算术平方根）", "phonetic": "", "hint": "标准差=方差的正平方根，与原数据单位相同", "example": "方差=4，标准差=√4=2", "tags": ["数学","公式","初中","统计"] },
    { "id": "math_049", "type": "word", "front": "概率基础（古典概型）", "back": "P(A) = A包含的等可能结果数 / 所有等可能结果总数", "phonetic": "", "hint": "等可能事件中，P(A)=有利结果/总结果", "example": "掷骰子，P(偶数)=3/6=1/2，即2,4,6出现的概率", "tags": ["数学","公式","初中","概率"] },
    { "id": "math_050", "type": "word", "front": "互斥事件概率", "back": "P(A或B) = P(A) + P(B)（A与B互不包含）", "phonetic": "", "hint": "两个事件不能同时发生，则其合并概率=各自概率之和", "example": "掷骰子，P(1或2)=P(1)+P(2)=1/6+1/6=1/3", "tags": ["数学","公式","初中","概率"] },
    { "id": "math_051", "type": "word", "front": "对立事件概率", "back": "P(A) + P(Ā) = 1，即P(Ā) = 1 - P(A)", "phonetic": "", "hint": "A不发生的概率=1减去A发生的概率", "example": "P(中奖)=0.1，P(不中奖)=1-0.1=0.9", "tags": ["数学","公式","初中","概率"] },
    { "id": "math_052", "type": "word", "front": "直线方程（斜截式）", "back": "y = kx + b（k=斜率，b=y轴截距）", "phonetic": "", "hint": "k是直线的倾斜程度，b是直线与y轴的交点纵坐标", "example": "过(0,2)斜率3的直线：y=3x+2", "tags": ["数学","公式","初中","函数"] },
    { "id": "math_053", "type": "word", "front": "斜率公式", "back": "k = (y₂-y₁)/(x₂-x₁)（两点确定斜率）", "phonetic": "", "hint": "斜率=纵坐标差/横坐标差，反映直线的倾斜程度", "example": "过(1,2)和(3,6)，k=(6-2)/(3-1)=4/2=2", "tags": ["数学","公式","初中","函数"] },
    { "id": "math_054", "type": "word", "front": "一次函数（正比例）", "back": "y = kx（k≠0），过原点，k>0递增，k<0递减", "phonetic": "", "hint": "b=0时为正比例函数，图像过原点", "example": "y=2x：x=1时y=2，x=2时y=4，x=3时y=6", "tags": ["数学","公式","初中","函数"] },
    { "id": "math_055", "type": "word", "front": "二次函数图像", "back": "y = ax²+bx+c（a≠0），a>0开口向上，a<0开口向下", "phonetic": "", "hint": "顶点x坐标=-b/(2a)，对称轴为x=-b/(2a)", "example": "y=x²-4x+3，对称轴x=2，顶点(2,-1)", "tags": ["数学","公式","初中","函数"] },
    { "id": "math_056", "type": "word", "front": "二次函数顶点坐标", "back": "顶点 = (-b/(2a), (4ac-b²)/(4a))", "phonetic": "", "hint": "顶点是抛物线的最高点（a<0）或最低点（a>0）", "example": "y=x²-4x+3，顶点=(-(-4)/(2×1), (4×1×3-16)/4)=(2,-1)", "tags": ["数学","公式","初中","函数"] },
    { "id": "math_057", "type": "word", "front": "反比例函数", "back": "y = k/x（k≠0），图像为双曲线", "phonetic": "", "hint": "k>0时在一三象限，k<0时在二四象限", "example": "y=6/x：x=2时y=3，x=3时y=2，xy乘积恒为6", "tags": ["数学","公式","初中","函数"] },
