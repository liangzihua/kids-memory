{
  "name": "kids-memory",
  "version": "1.0.0",
  "description": "儿童英语语文数学记忆辅助应用",
  "private": true,
  "scripts": {
    "serve": "node serve.js",
    "build": "npx esbuild app/ui.js --bundle --outfile=bundle.js --format=iife --platform=browser --target=es2020",
