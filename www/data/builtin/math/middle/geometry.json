{
  "meta": { "subject": "math", "grade": "middle", "name": "初中几何公式", "version": "2024", "count": 35 },
  "cards": [
    { "id": "geo_001", "type": "formula", "front": "勾股定理", "back": "直角三角形中：a² + b² = c²（c为斜边）", "example": "a=3, b=4 → c=√(9+16)=5", "tags": ["三角形","重要定理"] },
    { "id": "geo_002", "type": "formula", "front": "三角形面积", "back": "S = ½ × 底 × 高", "example": "底10，高6 → S=30", "tags": ["三角形","面积"] },
    { "id": "geo_003", "type": "concept", "front": "三角形三边关系", "back": "任意两边之和大于第三边\n任意两边之差小于第三边", "example": "3,4,5可以构成三角形；1,2,4不能", "tags": ["三角形"] },
    { "id": "geo_004", "type": "concept", "front": "三角形内角和", "back": "三角形三个内角之和 = 180°", "example": "已知两角60°和70°，第三角 = 50°", "tags": ["三角形","角"] },
    { "id": "geo_005", "type": "formula", "front": "平行四边形面积", "back": "S = 底 × 高", "hint": "注意高是底边上的垂线段，不是斜边", "tags": ["四边形","面积"] },
    { "id": "geo_006", "type": "formula", "front": "菱形面积", "back": "S = 对角线₁ × 对角线₂ ÷ 2", "example": "对角线6和8 → S = 24", "tags": ["四边形","面积"] },
    { "id": "geo_007", "type": "formula", "front": "梯形面积", "back": "S = (上底 + 下底) × 高 ÷ 2", "example": "上底4，下底8，高5 → S = 30", "tags": ["四边形","面积"] },
    { "id": "geo_008", "type": "formula", "front": "圆的面积", "back": "S = πr²", "example": "r=6 → S = 36π ≈ 113.1", "tags": ["圆","面积"] },
    { "id": "geo_009", "type": "formula", "front": "圆的周长", "back": "C = 2πr = πd", "example": "r=5 → C = 10π ≈ 31.4", "tags": ["圆","周长"] },
    { "id": "geo_010", "type": "formula", "front": "扇形面积", "back": "S = (n/360)πr²（n为圆心角度数）", "example": "r=6，圆心角90° → S = (1/4)×π×36 = 9π", "tags": ["圆","扇形"] },
    { "id": "geo_011", "type": "formula", "front": "弧长公式", "back": "l = (n/360) × 2πr = nπr/180", "example": "r=6，圆心角60° → l = π×6×60/180 = 2π", "tags": ["圆","弧长"] },
    { "id": "geo_012", "type": "formula", "front": "长方体表面积", "back": "S = 2(ab + ac + bc)（a,b,c为三边长）", "example": "2×3×4 → S = 2(6+8+12) = 52", "tags": ["立体几何","表面积"] },
    { "id": "geo_013", "type": "formula", "front": "长方体体积", "back": "V = abc（a,b,c为三边长）", "example": "2×3×4=24", "tags": ["立体几何","体积"] },
    { "id": "geo_014", "type": "formula", "front": "圆柱侧面积", "back": "S侧 = 2πrh（r底面半径，h高）", "example": "r=3，h=5 → S侧 = 30π", "tags": ["立体几何","圆柱"] },
    { "id": "geo_015", "type": "formula", "front": "圆柱全面积", "back": "S全 = 2πr(r+h)", "example": "r=3，h=5 → S全 = 2π×3×8 = 48π", "tags": ["立体几何","圆柱"] },
    { "id": "geo_016", "type": "formula", "front": "圆柱体积", "back": "V = πr²h", "example": "r=3，h=4 → V = 36π", "tags": ["立体几何","圆柱"] },
    { "id": "geo_017", "type": "formula", "front": "圆锥体积", "back": "V = ⅓πr²h（是等底等高圆柱的1/3）", "example": "r=3，h=4 → V = 12π", "tags": ["立体几何","圆锥"] },
    { "id": "geo_018", "type": "formula", "front": "圆锥侧面积", "back": "S侧 = πrl（l为母线长）", "hint": "l = √(r²+h²)", "tags": ["立体几何","圆锥"] },
    { "id": "geo_019", "type": "formula", "front": "球的体积", "back": "V = (4/3)πr³", "example": "r=3 → V = 36π", "tags": ["立体几何","球"] },
    { "id": "geo_020", "type": "formula", "front": "球的表面积", "back": "S = 4πr²", "example": "r=3 → S = 36π", "tags": ["立体几何","球"] },
    { "id": "geo_021", "type": "concept", "front": "直角三角形三角函数", "back": "sin A = 对边/斜边\ncos A = 邻边/斜边\ntan A = 对边/邻边", "hint": "记忆口诀：正弦对斜，余弦邻斜，正切对邻", "tags": ["三角函数"] },
    { "id": "geo_022", "type": "formula", "front": "sin30°, cos30°, tan30°", "back": "sin30°=1/2，cos30°=√3/2，tan30°=√3/3", "hint": "30-60-90三角形：边比=1:√3:2", "tags": ["三角函数","特殊角"] },
    { "id": "geo_023", "type": "formula", "front": "sin45°, cos45°, tan45°", "back": "sin45°=cos45°=√2/2，tan45°=1", "hint": "等腰直角三角形：边比=1:1:√2", "tags": ["三角函数","特殊角"] },
    { "id": "geo_024", "type": "formula", "front": "sin60°, cos60°, tan60°", "back": "sin60°=√3/2，cos60°=1/2，tan60°=√3", "hint": "30-60-90三角形", "tags": ["三角函数","特殊角"] },
    { "id": "geo_025", "type": "concept", "front": "相似三角形判定", "back": "①AA（两角相等）\n②SAS（两边比相等且夹角相等）\n③SSS（三边比相等）", "hint": "相似比=k，面积比=k²", "tags": ["相似三角形"] },
    { "id": "geo_026", "type": "concept", "front": "平行四边形判定", "back": "①两组对边分别平行\n②两组对边分别相等\n③一组对边平行且相等\n④对角线互相平分", "tags": ["四边形"] },
    { "id": "geo_027", "type": "concept", "front": "圆的切线定理", "back": "切线⊥过切点的半径\n过圆外一点的两条切线等长", "tags": ["圆","切线"] },
    { "id": "geo_028", "type": "concept", "front": "圆心角与圆周角", "back": "同弧所对圆心角 = 2倍圆周角\n同弧所对圆周角相等", "example": "圆心角80° → 同弧圆周角40°", "tags": ["圆","角"] },
    { "id": "geo_029", "type": "formula", "front": "两点间距离公式", "back": "d = √[(x₂-x₁)² + (y₂-y₁)²]", "example": "(0,0)到(3,4) → d=5", "tags": ["坐标系"] },
    { "id": "geo_030", "type": "formula", "front": "中点坐标公式", "back": "M = ((x₁+x₂)/2, (y₁+y₂)/2)", "example": "A(2,4),B(6,2) → 中点M(4,3)", "tags": ["坐标系"] }
  ]
}
